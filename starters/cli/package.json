{
  "name": "base-bun-cli",
  "version": "0.0.0",
  "private": false,
  "description": "Bun CLI template (dev on Bun, publish to Node)",
  "bin": {
    "mycli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "shadcn": "^4.5.0"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.6.2",
    "@infra-x/typescript-config": "^2.0.0",
    "@types/bun": "latest",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.62.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
