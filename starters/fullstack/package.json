{
  "name": "boilerplate",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test --continue",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint:fix && pnpm format && pnpm typecheck && pnpm test",
    "theme": "bun packages/cli/src/index.ts theme"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.4.0",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.59.0",
    "taze": "^19.10.0",
    "turbo": "^2.8.20"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "vite": "^8.0.1",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.10",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.17.23",
      "svgo": ">=3.3.3",
      "effect": ">=3.20.0"
    },
    "peerDependencyRules": {
      "allowAny": [
        "antd",
        "openapi-fetch",
        "storybook"
      ]
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "bcrypt",
      "better-sqlite3",
      "@swc/core",
      "esbuild"
    ]
  }
}
