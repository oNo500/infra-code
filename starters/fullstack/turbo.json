{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_URL"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "cache": false
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "lint:deps": {
      "inputs": ["src/**", ".dependency-cruiser.mjs", "tsconfig.json"]
    },
    "format": {
      "cache": false
    },
    "format:check": {},
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    }
  }
}
