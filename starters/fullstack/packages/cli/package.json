{
  "name": "@workspace/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Internal CLI tools for the monorepo",
  "bin": {
    "ws-cli": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun test --bail 0 || true"
  },
  "dependencies": {
    "citty": "^0.2.0",
    "execa": "^9.6.1",
    "pathe": "^2.0.3",
    "shadcn": "^4.3.1"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.5.0",
    "@infra-x/typescript-config": "^2.0.0",
    "@types/bun": "latest",
    "oxfmt": "^0.47.0",
    "oxlint": "^0.18.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.0"
  }
}
