{
  "name": "base-bun-server",
  "version": "0.0.0",
  "private": true,
  "description": "Bun HTTP service template (Hono + Drizzle + SQLite)",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun test"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.6.2",
    "@infra-x/typescript-config": "^2.0.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
