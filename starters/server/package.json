{
  "name": "base-bun-server",
  "version": "0.0.0",
  "private": true,
  "description": "Bun HTTP service template (Hono + Drizzle + SQLite)",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun test"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.4.0",
    "@infra-x/typescript-config": "^0.1.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.0"
  }
}
