{
  "name": "@infra-x/code-quality",
  "version": "0.3.2",
  "description": "Shared Oxlint + Oxfmt presets for infra-x projects. Lint and format, one install.",
  "license": "MIT",
  "author": "infra-x",
  "repository": {
    "type": "git",
    "url": "https://github.com/oNo500/infra-code.git",
    "directory": "packages/code-quality"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "lint": [
        "./dist/lint.d.mts"
      ],
      "format": [
        "./dist/format.d.mts"
      ]
    }
  },
  "exports": {
    "./format": "./dist/format.mjs",
    "./lint": "./dist/lint.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.28",
    "defu": "^6.1.7",
    "eslint-plugin-better-tailwindcss": "^4.3.1",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.2.14",
    "oxlint-tsgolint": "^0.20.0",
    "std-env": "^4.0.0"
  },
  "devDependencies": {
    "@infra-x/typescript-config": "workspace:*",
    "@types/node": "^25.3.3",
    "bumpp": "^10.4.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "oxlint": ">=1.59.0",
    "oxfmt": ">=0.44.0",
    "class-validator": "*",
    "storybook": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "storybook": {
      "optional": true
    }
  }
}
