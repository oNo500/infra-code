{
  "name": "boilerplate",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@infra-x/code-quality": "^0.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "turbo": "^2.8.12"
  },
  "packageManager": "pnpm@10.33.0"
}
