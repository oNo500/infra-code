{
  "name": "infra-code",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun --filter='*' run build",
    "typecheck": "bun --filter='*' run typecheck",
    "lint": "oxlint --disable-nested-config",
    "lint:fix": "oxlint --disable-nested-config --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "version": "bunx changeset version && bun install --no-frozen-lockfile",
    "release": "bunx changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@infra-x/code-quality": "^0.6.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1"
  }
}
